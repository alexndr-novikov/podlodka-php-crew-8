{% extends 'base.html.twig' %}

{% block title %}Email — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="section-title text-3xl gradient-text">Email (Mailpit)</h1>
        <p class="section-subtitle">Отправка email через Symfony Mailer → Mailpit SMTP</p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Отправить email</h2>
            <form method="post" action="{{ path('mail_send') }}" class="space-y-4">
                <div>
                    <label for="to" class="block text-sm font-medium text-pod-text-muted mb-1.5">To</label>
                    <input type="email" name="to" id="to" value="test@example.com" class="pod-input">
                </div>
                <div>
                    <label for="subject" class="block text-sm font-medium text-pod-text-muted mb-1.5">Subject</label>
                    <input type="text" name="subject" id="subject" value="Test from Docker Workshop" class="pod-input">
                </div>
                <div>
                    <label for="body" class="block text-sm font-medium text-pod-text-muted mb-1.5">Body</label>
                    <textarea name="body" id="body" rows="3" class="pod-input">Hello from Symfony + Mailpit!</textarea>
                </div>
                <button type="submit" class="pod-btn pod-btn-primary">Отправить</button>
            </form>
        </div>

        <div class="glass-card p-6 h-fit">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Сервис</h2>
            <dl class="pod-dl space-y-3 text-sm">
                <div class="flex justify-between">
                    <dt>SMTP</dt>
                    <dd class="pod-mono">mailpit:1025</dd>
                </div>
                <div class="flex justify-between">
                    <dt>Symfony DSN</dt>
                    <dd class="pod-mono">smtp://mailpit:1025</dd>
                </div>
            </dl>
            <a href="https://mailpit.workshop.localhost" target="_blank"
               class="mt-5 inline-flex items-center gap-1 text-sm pod-link">
                Открыть Mailpit UI
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
        </div>
    </div>
{% endblock %}
