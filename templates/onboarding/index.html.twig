{% extends 'base.html.twig' %}

{% block title %}Onboarding — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="section-title text-3xl gradient-text">Onboarding</h1>
        <p class="section-subtitle">Сквозной сценарий: PostgreSQL + S3 + Meilisearch + Messenger + Mailpit</p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Регистрация пользователя</h2>
            <form method="post" action="{{ path('onboarding_register') }}" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-pod-text-muted mb-1.5">Имя</label>
                    <input type="text" name="name" id="name" required placeholder="Алексей Иванов" class="pod-input">
                </div>
                <div>
                    <label for="email" class="block text-sm font-medium text-pod-text-muted mb-1.5">Email</label>
                    <input type="email" name="email" id="email" required placeholder="alexey@example.com" class="pod-input">
                </div>
                <div>
                    <label for="avatar" class="block text-sm font-medium text-pod-text-muted mb-1.5">Аватар (опционально)</label>
                    <input type="file" name="avatar" id="avatar" accept="image/*" class="pod-input pod-input-file">
                </div>
                <button type="submit" class="pod-btn pod-btn-primary">Зарегистрировать</button>
            </form>
        </div>

        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Что произойдёт</h2>
            <ol class="space-y-4 text-sm text-pod-text-muted">
                <li class="flex gap-3">
                    <span class="font-bold text-pod-purple-light font-display text-base">1.</span>
                    <span>User сохраняется в <strong class="text-pod-text">PostgreSQL</strong> (Doctrine ORM)</span>
                </li>
                <li class="flex gap-3">
                    <span class="font-bold text-pod-purple-light font-display text-base">2.</span>
                    <span>Аватар загружается в <strong class="text-pod-text">S3</strong> (Flysystem + LocalStack)</span>
                </li>
                <li class="flex gap-3">
                    <span class="font-bold text-pod-purple-light font-display text-base">3.</span>
                    <span>Профиль индексируется в <strong class="text-pod-text">Meilisearch</strong></span>
                </li>
                <li class="flex gap-3">
                    <span class="font-bold text-pod-purple-light font-display text-base">4.</span>
                    <span>Welcome email отправляется async через <strong class="text-pod-text">Messenger</strong> + <strong class="text-pod-text">Valkey</strong></span>
                </li>
                <li class="flex gap-3">
                    <span class="font-bold text-pod-purple-light font-display text-base">5.</span>
                    <span>Результат виден в <strong class="text-pod-text">Mailpit</strong></span>
                </li>
            </ol>
            <div class="mt-5 space-y-2">
                <a href="https://mailpit.workshop.localhost:8443" target="_blank"
                   class="inline-flex items-center gap-1 text-sm pod-link">
                    Mailpit UI
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
                <a href="https://search.workshop.localhost:8443" target="_blank"
                   class="inline-flex items-center gap-1 text-sm pod-link">
                    Meilisearch
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
            </div>
        </div>
    </div>
{% endblock %}
