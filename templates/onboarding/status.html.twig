{% extends 'base.html.twig' %}

{% block title %}User #{{ user.id }} — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="section-title text-3xl gradient-text">User registered</h1>
        <p class="section-subtitle">Статус обработки для {{ user.name }}</p>
    </div>

    <div class="glass-card p-6 max-w-lg">
        <dl class="pod-dl space-y-4">
            <div class="flex justify-between border-b border-pod-border pb-3">
                <dt class="text-sm">ID</dt>
                <dd class="text-sm font-medium text-pod-text">{{ user.id }}</dd>
            </div>
            <div class="flex justify-between border-b border-pod-border pb-3">
                <dt class="text-sm">Name</dt>
                <dd class="text-sm font-medium text-pod-text">{{ user.name }}</dd>
            </div>
            <div class="flex justify-between border-b border-pod-border pb-3">
                <dt class="text-sm">Email</dt>
                <dd class="text-sm font-medium text-pod-text">{{ user.email }}</dd>
            </div>
            <div class="flex justify-between border-b border-pod-border pb-3">
                <dt class="text-sm">Avatar</dt>
                <dd class="text-sm font-medium text-pod-text">{{ user.avatarUrl ?? 'none' }}</dd>
            </div>
            <div class="flex justify-between">
                <dt class="text-sm">Created</dt>
                <dd class="text-sm font-medium text-pod-text">{{ user.createdAt|date('Y-m-d H:i:s') }}</dd>
            </div>
        </dl>

        <div class="mt-6 flex flex-wrap gap-3">
            <a href="https://mailpit.workshop.localhost:8443" target="_blank"
               class="pod-btn pod-btn-ghost">
                Check Mailpit
            </a>
            <a href="{{ path('onboarding_index') }}"
               class="pod-btn pod-btn-ghost">
                Register another
            </a>
            <a href="{{ path('dashboard') }}"
               class="pod-btn pod-btn-ghost">
                Dashboard
            </a>
        </div>
    </div>
{% endblock %}
