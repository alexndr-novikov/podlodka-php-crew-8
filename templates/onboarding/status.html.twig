{% extends 'base.html.twig' %}

{% block title %}User #{{ user.id }} — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">User registered</h1>
        <p class="mt-1 text-gray-500">Статус обработки для {{ user.name }}</p>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm max-w-lg">
        <dl class="space-y-4">
            <div class="flex justify-between border-b pb-2">
                <dt class="text-sm text-gray-500">ID</dt>
                <dd class="text-sm font-medium text-gray-900">{{ user.id }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-sm text-gray-500">Name</dt>
                <dd class="text-sm font-medium text-gray-900">{{ user.name }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-sm text-gray-500">Email</dt>
                <dd class="text-sm font-medium text-gray-900">{{ user.email }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-sm text-gray-500">Avatar</dt>
                <dd class="text-sm font-medium text-gray-900">{{ user.avatarUrl ?? 'none' }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-sm text-gray-500">Created</dt>
                <dd class="text-sm font-medium text-gray-900">{{ user.createdAt|date('Y-m-d H:i:s') }}</dd>
            </div>
        </dl>

        <div class="mt-6 flex gap-3">
            <a href="https://mailpit.workshop.localhost:8443" target="_blank"
               class="rounded-md bg-indigo-50 px-3 py-2 text-sm font-medium text-indigo-600 hover:bg-indigo-100">
                Check Mailpit
            </a>
            <a href="{{ path('onboarding_index') }}"
               class="rounded-md bg-gray-50 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100">
                Register another
            </a>
            <a href="{{ path('dashboard') }}"
               class="rounded-md bg-gray-50 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100">
                Dashboard
            </a>
        </div>
    </div>
{% endblock %}
