{% extends 'base.html.twig' %}

{% block title %}Dashboard — Docker Workshop{% endblock %}

{% block body %}
    <div class="hero-gradient mb-10">
        <h1 class="section-title text-4xl sm:text-5xl gradient-text">Docker Workshop</h1>
        <p class="section-subtitle mt-3 max-w-xl">
            Демо-приложение: Symfony 7.2 + FrankenPHP + полный стек инфраструктуры
        </p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {% for demo in demos %}
            <div class="dash-card glass-card p-6 group cursor-pointer relative overflow-hidden"
                 onclick="window.location='{{ path(demo.route) }}'">
                {# Hover glow #}
                <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full bg-pod-purple/5 blur-2xl transition-all duration-500 group-hover:bg-pod-purple/15 group-hover:w-40 group-hover:h-40"></div>

                <div class="icon-glow mb-4 relative">{{ demo.icon }}</div>
                <h3 class="text-lg font-semibold text-pod-text font-display tracking-tight">{{ demo.title }}</h3>
                <p class="mt-2 text-sm text-pod-text-muted leading-relaxed">{{ demo.description }}</p>
                <div class="mt-5 flex items-center justify-between">
                    <a href="{{ path(demo.route) }}"
                       class="text-sm font-medium pod-link inline-flex items-center gap-1 group-hover:text-pod-green-light transition-colors duration-300">
                        Открыть
                        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                        </svg>
                    </a>
                    {% if demo.serviceUrl %}
                        <a href="{{ demo.serviceUrl }}"
                           target="_blank"
                           class="text-xs text-pod-text-dim hover:text-pod-text-muted transition-colors duration-200">
                            {{ demo.service }} ↗
                        </a>
                    {% else %}
                        <span class="text-xs text-pod-text-dim">{{ demo.service }}</span>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
