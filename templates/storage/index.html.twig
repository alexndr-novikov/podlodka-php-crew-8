{% extends 'base.html.twig' %}

{% block title %}Storage (S3) — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="section-title text-3xl gradient-text">Storage (S3)</h1>
        <p class="section-subtitle">Upload файлов в LocalStack S3 через Flysystem</p>
        <a href="https://s3.workshop.localhost:8443" target="_blank" rel="noopener"
           class="inline-flex items-center gap-1.5 mt-3 text-sm text-pod-accent hover:text-pod-accent-hover transition-colors">
            <span>Открыть S3 Manager UI</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
        </a>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Upload файла</h2>
            <form method="post" action="{{ path('storage_upload') }}" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label for="file" class="block text-sm font-medium text-pod-text-muted mb-1.5">Файл</label>
                    <input type="file" name="file" id="file" class="pod-input-file pod-input">
                </div>
                <button type="submit" class="pod-btn pod-btn-primary">Upload</button>
            </form>
        </div>

        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Файлы в bucket</h2>
            {% if files is empty %}
                <p class="text-sm text-pod-text-dim">Bucket пуст</p>
            {% else %}
                <ul class="space-y-3">
                    {% for file in files %}
                        <li class="flex items-center justify-between text-sm rounded-lg bg-pod-bg/50 p-3 border border-pod-border">
                            <span class="text-pod-text font-mono text-xs truncate">{{ file.path }}</span>
                            <div class="flex items-center gap-3">
                                {% if file.size is not null %}
                                    <span class="text-pod-text-dim text-xs">{{ (file.size / 1024)|round(1) }} KB</span>
                                {% endif %}
                                <form method="post" action="{{ path('storage_delete', {path: file.path}) }}" class="inline">
                                    <button type="submit" class="text-red-400 hover:text-red-300 text-xs font-medium transition-colors">Delete</button>
                                </form>
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </div>
{% endblock %}
