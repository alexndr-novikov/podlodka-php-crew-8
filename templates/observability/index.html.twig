{% extends 'base.html.twig' %}

{% block title %}Observability — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="section-title text-3xl gradient-text">Observability</h1>
        <p class="section-subtitle">Трейсы, логи, метрики через OpenTelemetry → Grafana LGTM</p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-4">Генерация трейса</h2>
            <p class="text-sm text-pod-text-muted mb-5">Создаёт трейс и несколько логов разного уровня (info, warning, error)</p>
            <form method="post" action="{{ path('observability_trace') }}">
                <button type="submit" class="pod-btn pod-btn-primary">Generate Trace + Logs</button>
            </form>
        </div>

        <div class="glass-card p-6">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Сервисы</h2>
            <dl class="pod-dl space-y-3 text-sm">
                <div class="flex justify-between">
                    <dt>OTel Collector</dt>
                    <dd class="pod-mono">otel-lgtm:4318</dd>
                </div>
                <div class="flex justify-between">
                    <dt>Grafana</dt>
                    <dd class="pod-mono">otel-lgtm:3000</dd>
                </div>
            </dl>
            <div class="mt-5 space-y-2">
                <a href="https://grafana.workshop.localhost:8443" target="_blank"
                   class="inline-flex items-center gap-1 text-sm pod-link">
                    Открыть Grafana
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
                <p class="text-xs text-pod-text-dim">OTel PHP SDK будет подключён позже. Логи доступны через Monolog.</p>
            </div>
        </div>
    </div>
{% endblock %}
