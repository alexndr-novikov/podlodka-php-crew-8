{% extends 'base.html.twig' %}

{% block title %}Search — Docker Workshop{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="section-title text-3xl gradient-text">Search (Meilisearch)</h1>
        <p class="section-subtitle">Полнотекстовый поиск с typo-tolerance</p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <div class="space-y-6">
            <div class="glass-card p-6">
                <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Поиск</h2>
                <form method="get" action="{{ path('search_index') }}">
                    <div class="flex gap-3">
                        <input type="text" name="q" value="{{ query }}" placeholder="Введите запрос..." class="pod-input flex-1">
                        <button type="submit" class="pod-btn pod-btn-primary">Найти</button>
                    </div>
                </form>

                {% if results.hits is defined and results.hits is not empty %}
                    <ul class="mt-5 space-y-2">
                        {% for hit in results.hits %}
                            <li class="rounded-lg bg-pod-bg/50 border border-pod-border p-3 text-sm">
                                <span class="font-medium text-pod-text">{{ hit.name ?? hit.id }}</span>
                                {% if hit.email is defined %}
                                    <span class="text-pod-text-dim ml-2">{{ hit.email }}</span>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                    <p class="mt-3 text-xs text-pod-text-dim">{{ results.estimatedTotalHits ?? 0 }} results in {{ results.processingTimeMs ?? 0 }}ms</p>
                {% elseif query %}
                    <p class="mt-5 text-sm text-pod-text-dim">Ничего не найдено</p>
                {% endif %}
            </div>

            <div class="glass-card p-6">
                <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Добавить документ</h2>
                <form method="post" action="{{ path('search_add') }}" class="space-y-3">
                    <input type="text" name="name" placeholder="Имя" required class="pod-input">
                    <input type="email" name="email" placeholder="Email" required class="pod-input">
                    <button type="submit" class="pod-btn pod-btn-success">Добавить</button>
                </form>
            </div>
        </div>

        <div class="glass-card p-6 h-fit">
            <h2 class="text-lg font-semibold text-pod-text font-display mb-5">Сервис</h2>
            <dl class="pod-dl space-y-3 text-sm">
                <div class="flex justify-between">
                    <dt>URL</dt>
                    <dd class="pod-mono">meilisearch:7700</dd>
                </div>
            </dl>
            <a href="https://search.workshop.localhost" target="_blank"
               class="mt-5 inline-flex items-center gap-1 text-sm pod-link">
                Открыть Meilisearch
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
        </div>
    </div>
{% endblock %}
