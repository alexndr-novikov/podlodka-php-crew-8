{
    {$CADDY_GLOBAL_OPTIONS}

    frankenphp {
        {$FRANKENPHP_CONFIG}
    }

    order php_server before file_server
}

{$SERVER_NAME:localhost} {
    log {
        level {$CADDY_LOG_LEVEL:INFO}
    }

    root * /app/public
    encode zstd br gzip

    {$CADDY_SERVER_EXTRA_DIRECTIVES}

    php_server {
        worker {
            file ./public/index.php
            {$FRANKENPHP_WORKER_CONFIG}
        }
    }
}
